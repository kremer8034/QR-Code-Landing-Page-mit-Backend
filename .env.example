# --- Supabase (database + storage) ---
# Project API URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Service-role key (Supabase Dashboard -> Project Settings -> API -> service_role).
# Server-only secret. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
# Long random string used to sign backoffice session cookies.
# Generate e.g. with: openssl rand -hex 32
SESSION_SECRET=

# Optional fallback base URL for QR links (normally set in the backoffice under
# Einstellungen -> Darstellung -> Basis-URL für QR-Codes).
APP_BASE_URL=
